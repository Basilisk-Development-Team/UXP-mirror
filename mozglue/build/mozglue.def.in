  MOZ_Z_gzrewind
  MOZ_Z_gztell
  MOZ_Z_gzoffset
  MOZ_Z_gzeof
  MOZ_Z_gzdirect
  MOZ_Z_gzclose
  MOZ_Z_gzclose_r
  MOZ_Z_gzclose_w
  MOZ_Z_gzerror
  MOZ_Z_gzclearerr
  MOZ_Z_gzopen64
  MOZ_Z_gzseek64
  MOZ_Z_gztell64
